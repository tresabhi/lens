---
import { Grid } from "@radix-ui/themes";
import { tmdb } from "../constants/tmdb";
import Movie from "./Movie.astro";
import { SectionWrapper } from "./SectionWrapper";

const movies = await tmdb
  .allAccountRatedMovies(import.meta.env.TMDB_ACCOUNT)
  .then((movies) =>
    movies.sort((a, b) => b.release_date.localeCompare(a.release_date))
  );
---

<SectionWrapper>
  <Grid
    columns={{
      initial: "repeat(auto-fill, minmax(8rem, 1fr))",
      xs: "repeat(auto-fill, minmax(10rem, 1fr))",
      sm: "repeat(auto-fill, minmax(12rem, 1fr))",
      md: "repeat(auto-fill, minmax(14rem, 1fr))",
    }}
    flow="dense"
    gap="5"
  >
    {movies.map((movie) => <Movie {movie} />)}
  </Grid>
</SectionWrapper>
