---
import { tmdb } from "../constants/tmdb";
import { MovieWrapped } from "./MovieWrapped";

interface Props {
  movie: TMDB.AccountRatedMoviesResult;
}

const { movie } = Astro.props;
---

<MovieWrapped
  client:load
  {movie}
  poster={await tmdb.image(movie.poster_path, "w342")}
  backdrop={await tmdb.image(movie.backdrop_path, "w1280")}
/>
